DEVSHARE_LISTEN=:8080
DEVSHARE_PUBLIC_URL=https://share.example.com
DEVSHARE_SITE_DOMAIN=example.com
DEVSHARE_DATA_DIR=/var/lib/devshare
DEVSHARE_DEFAULT_TTL=24h
DEVSHARE_MAX_TTL=168h

# generate with: openssl rand -hex 32
DEVSHARE_BOOTSTRAP_TOKEN=ds_replace_me

# optional. required only for dashboard/private links
DEVSHARE_OIDC_ISSUER=https://auth.example.com/application/o/devshare/
DEVSHARE_OIDC_CLIENT_ID=
DEVSHARE_OIDC_CLIENT_SECRET=
